# Gmail account that will SEND the reports.
# Use a Gmail App Password (https://myaccount.google.com/apppasswords),
# NOT your real account password.
EMAIL=yourgmail@gmail.com
PASSWORD=your-app-password

# Optional: override the "from" name shown to recipients.
FROM_NAME=FFA Investments

# Optional: send a single consolidated email here instead of one per member.
# Leave blank to send a personalized email to each member.
OPERATOR_EMAIL=

# Optional: dry-run mode (build HTML only, do not send any email).
# Set to "true" to disable sending.
DRY_RUN=false
